# CareerPilot AI — central environment file
# Copy to .env in this directory (project root):
#   cp .env.example .env

# ── Backend ──────────────────────────────────────────────────────────────────
APP_NAME=CareerPilot AI
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# DATABASE_URL=sqlite:///./backend/careerpilot.db

# ── Gemini (resume extraction) ─────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Frontend (Vite reads from project root via envDir) ───────────────────────
VITE_API_URL=http://localhost:8000
